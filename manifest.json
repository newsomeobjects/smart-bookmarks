{
    "manifest_version": 3,
    "name": "智能书签分类器",
    "version": "1.0.0",
    "description": "基于AI的智能书签自动分类与管理工具",
    "permissions": [
        "bookmarks",
        "tabs",
        "storage",
        "notifications",
        "favicon"
    ],
    "background": {
        "service_worker": "background.js"
    },
    "action": {
        "default_popup": "popup.html",
        "default_icon": {
            "16": "icons/icon16.png",
            "48": "icons/icon48.png",
            "128": "icons/icon128.png"
        },
        "default_title": "智能书签分类器"
    },
    "options_page": "manager.html",
    "icons": {
        "16": "icons/icon16.png",
        "48": "icons/icon48.png",
        "128": "icons/icon128.png"
    },
    "web_accessible_resources": [
        {
            "resources": ["manager.html", "manager.js", "components/*", "prompts/*", "_favicon/*"],
            "matches": ["<all_urls>"]
        }
    ]
}
